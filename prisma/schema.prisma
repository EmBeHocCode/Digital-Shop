generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductDomain {
  INFRASTRUCTURE
  DIGITAL_GOODS
  TELECOM
}

enum MarketingPage {
  LANDING
  SERVICES
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  WALLET
  BANK_TRANSFER
  MANUAL_CONFIRMATION
}

enum PaymentProvider {
  INTERNAL_WALLET
  MANUAL_BANK_TRANSFER
  MANUAL_REVIEW
  STRIPE
  VNPAY
}

enum PaymentIntentStatus {
  PENDING
  REQUIRES_ACTION
  SUCCEEDED
  FAILED
  CANCELED
}

enum WalletStatus {
  ACTIVE
  LOCKED
  CLOSED
}

enum TransactionType {
  TOPUP
  PAYMENT
  REFUND
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum ProductOptionType {
  CHOICE
  BILLING_CYCLE
  DENOMINATION
}

enum InventoryNumberStatus {
  AVAILABLE
  RESERVED
  SOLD
  ARCHIVED
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
  CANCELED
}

enum DeliveryStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
  REVOKED
}

enum ProvisionStatus {
  QUEUED
  PROVISIONING
  ACTIVE
  SUSPENDED
  TERMINATED
  FAILED
}

enum SecurityEventType {
  SIGN_IN
  SIGN_OUT
  REGISTER
  PASSWORD_RESET
  PROFILE_UPDATED
  PAYMENT_ACTION
}

enum InventoryMovementType {
  IMPORT
  RESERVE
  RELEASE
  SALE
  REFUND
  ADJUSTMENT
  EXPIRE
}

enum ForecastHorizon {
  DAILY
  WEEKLY
  MONTHLY
}

enum AiSessionChannel {
  WEB
  DASHBOARD
  ADMIN
  API
}

enum AiMessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum AiRecommendationType {
  INVENTORY
  PROFIT
  PRICING
  MARKET
  DEMAND
  OPERATIONS
}

enum AiRecommendationStatus {
  OPEN
  APPLIED
  DISMISSED
  ARCHIVED
}

model User {
  id            String        @id @default(uuid()) @db.Uuid
  email         String        @unique
  name          String?
  passwordHash  String?
  role          UserRole      @default(USER)
  image         String?
  phone         String?
  emailVerified DateTime?
  isActive      Boolean       @default(true)
  wallet        Wallet?
  cart          Cart?
  preference    UserPreference?
  orders        Order[]
  transactions  Transaction[]
  paymentIntents PaymentIntent[]
  refundRequests RefundRequest[]
  securityEvents SecurityEvent[]
  passwordResetTokens PasswordResetToken[]
  aiSessions    AiConversationSession[]
  aiRecommendations AiRecommendation[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([role])
  @@index([createdAt])
}

model Product {
  id          String        @id @default(uuid()) @db.Uuid
  slug        String        @unique
  name        String
  tagline     String?
  description String?
  price       Decimal       @db.Decimal(12, 2)
  priceLabel  String?
  currency    String        @default("VND") @db.VarChar(3)
  domain      ProductDomain
  category    String
  isFeatured  Boolean       @default(false)
  sortOrder   Int           @default(0)
  status      ProductStatus @default(DRAFT)
  imageUrl    String?
  metadata    Json?
  orderItems  OrderItem[]
  media       ProductMedia[]
  faqs        ProductFaq[]
  optionGroups ProductOptionGroup[]
  denominations ProductDenomination[]
  inventoryNumbers ProductInventoryNumber[]
  cartItems   CartItem[]
  inventoryBalances InventoryBalance[]
  inventoryMovements InventoryMovement[]
  costSnapshots ProductCostSnapshot[]
  priceSnapshots ProductPriceSnapshot[]
  salesMetrics ProductSalesMetric[]
  marketSnapshots MarketTrendSnapshot[]
  forecastSnapshots ForecastSnapshot[]
  aiRecommendations AiRecommendation[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([domain, status])
  @@index([category, status])
  @@index([isFeatured, status, sortOrder])
  @@index([status, createdAt])
}

model Order {
  id              String            @id @default(uuid()) @db.Uuid
  userId          String            @db.Uuid
  user            User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  status          OrderStatus       @default(PENDING)
  totalAmount     Decimal           @db.Decimal(12, 2)
  currency        String            @default("VND") @db.VarChar(3)
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  paymentMethod   PaymentMethod     @default(MANUAL_CONFIRMATION)
  paymentProvider PaymentProvider   @default(MANUAL_REVIEW)
  paymentStatus   TransactionStatus @default(PENDING)
  paymentReference String?          @unique
  note            String?
  items           OrderItem[]
  transactions    Transaction[]
  paymentIntents  PaymentIntent[]
  refundRequests  RefundRequest[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId, status])
  @@index([userId, paymentStatus])
  @@index([paymentMethod, paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id          String   @id @default(uuid()) @db.Uuid
  orderId     String   @db.Uuid
  productId   String   @db.Uuid
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  productName String
  unitPrice   Decimal  @db.Decimal(12, 2)
  quantity    Int
  totalPrice  Decimal  @db.Decimal(12, 2)
  metadata    Json?
  serviceProvisions ServiceProvision[]
  digitalDeliveries DigitalDelivery[]
  inventoryMovements InventoryMovement[]
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

model Cart {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @unique @db.Uuid
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    CartStatus @default(ACTIVE)
  currency  String     @default("VND") @db.VarChar(3)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status, updatedAt])
}

model CartItem {
  id          String   @id @default(uuid()) @db.Uuid
  cartId      String   @db.Uuid
  productId   String   @db.Uuid
  lineId      String
  productName String
  unitPrice   Decimal  @db.Decimal(12, 2)
  quantity    Int
  metadata    Json?
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([cartId, lineId])
  @@index([productId])
}

model Wallet {
  id           String         @id @default(uuid()) @db.Uuid
  userId       String         @unique @db.Uuid
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance      Decimal        @default(0) @db.Decimal(12, 2)
  currency     String         @default("VND") @db.VarChar(3)
  status       WalletStatus   @default(ACTIVE)
  transactions Transaction[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status])
}

model Transaction {
  id              String            @id @default(uuid()) @db.Uuid
  userId          String            @db.Uuid
  walletId        String?           @db.Uuid
  orderId         String?           @db.Uuid
  user            User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  wallet          Wallet?           @relation(fields: [walletId], references: [id], onDelete: SetNull)
  order           Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  type            TransactionType
  paymentMethod   PaymentMethod?
  paymentProvider PaymentProvider?
  status          TransactionStatus @default(PENDING)
  amount          Decimal           @db.Decimal(12, 2)
  currency        String            @default("VND") @db.VarChar(3)
  description     String?
  reference       String?           @unique
  metadata        Json?
  paymentIntent   PaymentIntent?
  refundRequests  RefundRequest[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId, status])
  @@index([walletId])
  @@index([orderId])
  @@index([type, createdAt])
}

model UserPreference {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @db.Uuid
  preferredTheme String?
  locale         String?
  currency       String   @default("VND") @db.VarChar(3)
  marketingEmails Boolean @default(true)
  orderEmails    Boolean  @default(true)
  billingEmails  Boolean  @default(true)
  metadata       Json?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SecurityEvent {
  id        String            @id @default(uuid()) @db.Uuid
  userId    String            @db.Uuid
  type      SecurityEventType
  ipAddress String?
  userAgent String?
  metadata  Json?
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())

  @@index([userId, type, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model ProductMedia {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  kind      String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  metadata  Json?
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, sortOrder])
}

model ProductFaq {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @db.Uuid
  question    String
  answer      String
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId, sortOrder])
}

model ProductOptionGroup {
  id          String            @id @default(uuid()) @db.Uuid
  productId   String            @db.Uuid
  key         String
  label       String
  type        ProductOptionType
  description String?
  helperText  String?
  isRequired  Boolean           @default(true)
  sortOrder   Int               @default(0)
  metadata    Json?
  product     Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  values      ProductOptionValue[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([productId, key])
  @@index([productId, sortOrder])
}

model ProductOptionValue {
  id              String             @id @default(uuid()) @db.Uuid
  groupId         String             @db.Uuid
  key             String
  label           String
  description     String?
  priceAdjustment Decimal?           @db.Decimal(12, 2)
  badge           String?
  isDefault       Boolean            @default(false)
  sortOrder       Int                @default(0)
  metadata        Json?
  group           ProductOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([groupId, key])
  @@index([groupId, sortOrder])
}

model ProductDenomination {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  key       String
  label     String
  amount    Decimal  @db.Decimal(12, 2)
  note      String?
  isDefault Boolean  @default(false)
  sortOrder Int      @default(0)
  metadata  Json?
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, key])
  @@index([productId, sortOrder])
}

model ProductInventoryNumber {
  id           String                @id @default(uuid()) @db.Uuid
  productId    String                @db.Uuid
  key          String
  providerKey  String
  categoryKey  String
  value        String
  price        Decimal               @db.Decimal(12, 2)
  status       InventoryNumberStatus @default(AVAILABLE)
  tags         Json?
  reservedUntil DateTime?
  metadata     Json?
  sortOrder    Int                   @default(0)
  product      Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([productId, key])
  @@index([productId, status, sortOrder])
}

model MarketingSection {
  id          String        @id @default(uuid()) @db.Uuid
  page        MarketingPage
  key         String
  title       String
  subtitle    String?
  body        String?
  ctaLabel    String?
  ctaHref     String?
  metadata    Json?
  isPublished Boolean       @default(true)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([page, key])
  @@index([page, sortOrder])
}

model MarketingFaq {
  id          String        @id @default(uuid()) @db.Uuid
  page        MarketingPage
  question    String
  answer      String
  isPublished Boolean       @default(true)
  sortOrder   Int           @default(0)
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([page, sortOrder])
}

model Testimonial {
  id          String        @id @default(uuid()) @db.Uuid
  page        MarketingPage @default(LANDING)
  name        String
  role        String?
  company     String?
  quote       String
  initials    String?
  rating      Int           @default(5)
  isPublished Boolean       @default(true)
  sortOrder   Int           @default(0)
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([page, sortOrder])
}

model PricingPlan {
  id           String        @id @default(uuid()) @db.Uuid
  page         MarketingPage @default(LANDING)
  slug         String        @unique
  name         String
  description  String?
  monthlyPrice Decimal?      @db.Decimal(12, 2)
  yearlyPrice  Decimal?      @db.Decimal(12, 2)
  currency     String        @default("VND") @db.VarChar(3)
  specs        String?
  features     Json?
  ctaLabel     String?
  ctaHref      String?
  isFeatured   Boolean       @default(false)
  isPublished  Boolean       @default(true)
  sortOrder    Int           @default(0)
  metadata     Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([page, sortOrder])
}

model PaymentIntent {
  id               String              @id @default(uuid()) @db.Uuid
  userId           String              @db.Uuid
  orderId          String?             @db.Uuid
  transactionId    String?             @unique @db.Uuid
  provider         PaymentProvider
  method           PaymentMethod
  status           PaymentIntentStatus @default(PENDING)
  amount           Decimal             @db.Decimal(12, 2)
  currency         String              @default("VND") @db.VarChar(3)
  reference        String?             @unique
  externalIntentId String?
  clientSecret     String?
  metadata         Json?
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  order            Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  transaction      Transaction?        @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([userId, status])
  @@index([orderId])
}

model PaymentWebhookEvent {
  id          String          @id @default(uuid()) @db.Uuid
  provider    PaymentProvider
  eventId     String          @unique
  eventType   String
  payload     Json
  processedAt DateTime?
  createdAt   DateTime        @default(now())

  @@index([provider, createdAt])
}

model RefundRequest {
  id            String       @id @default(uuid()) @db.Uuid
  userId        String       @db.Uuid
  orderId       String?      @db.Uuid
  transactionId String?      @db.Uuid
  status        RefundStatus @default(REQUESTED)
  amount        Decimal      @db.Decimal(12, 2)
  currency      String       @default("VND") @db.VarChar(3)
  reason        String
  note          String?
  metadata      Json?
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  order         Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId, status])
  @@index([orderId])
  @@index([transactionId])
}

model ServiceProvision {
  id            String          @id @default(uuid()) @db.Uuid
  orderItemId   String          @db.Uuid
  status        ProvisionStatus @default(QUEUED)
  providerKey   String?
  region        String?
  config        Json?
  accessData    Json?
  provisionedAt DateTime?
  suspendedAt   DateTime?
  terminatedAt  DateTime?
  orderItem     OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([orderItemId, status])
}

model DigitalDelivery {
  id          String         @id @default(uuid()) @db.Uuid
  orderItemId String         @db.Uuid
  status      DeliveryStatus @default(PENDING)
  channel     String?
  payload     Json?
  deliveredAt DateTime?
  orderItem   OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([orderItemId, status])
}

model InventoryBalance {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  scopeKey  String   @default("default")
  onHand    Int      @default(0)
  reserved  Int      @default(0)
  sold      Int      @default(0)
  available Int      @default(0)
  metadata  Json?
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, scopeKey])
  @@index([productId, updatedAt])
}

model InventoryMovement {
  id         String                @id @default(uuid()) @db.Uuid
  productId  String                @db.Uuid
  orderItemId String?              @db.Uuid
  type       InventoryMovementType
  quantityDelta Int
  unitCost   Decimal?              @db.Decimal(12, 2)
  note       String?
  metadata   Json?
  product    Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItem  OrderItem?            @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  createdAt  DateTime              @default(now())

  @@index([productId, type, createdAt])
  @@index([orderItemId])
}

model ProductCostSnapshot {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @db.Uuid
  unitCost    Decimal  @db.Decimal(12, 2)
  overheadCost Decimal? @db.Decimal(12, 2)
  source      String?
  effectiveFrom DateTime
  metadata    Json?
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([productId, effectiveFrom])
}

model ProductPriceSnapshot {
  id            String   @id @default(uuid()) @db.Uuid
  productId     String   @db.Uuid
  salePrice     Decimal  @db.Decimal(12, 2)
  compareAtPrice Decimal? @db.Decimal(12, 2)
  source        String?
  effectiveFrom DateTime
  metadata      Json?
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@index([productId, effectiveFrom])
}

model ProductSalesMetric {
  id           String   @id @default(uuid()) @db.Uuid
  productId    String   @db.Uuid
  metricDate   DateTime
  ordersCount  Int      @default(0)
  unitsSold    Int      @default(0)
  grossRevenue Decimal  @db.Decimal(12, 2)
  netRevenue   Decimal  @db.Decimal(12, 2)
  grossProfit  Decimal? @db.Decimal(12, 2)
  netProfit    Decimal? @db.Decimal(12, 2)
  currency     String   @default("VND") @db.VarChar(3)
  metadata     Json?
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([productId, metricDate])
  @@index([metricDate])
}

model MarketTrendSnapshot {
  id               String        @id @default(uuid()) @db.Uuid
  productId        String?       @db.Uuid
  domain           ProductDomain?
  category         String?
  snapshotDate     DateTime
  demandScore      Decimal?      @db.Decimal(8, 4)
  competitionScore Decimal?      @db.Decimal(8, 4)
  trendScore       Decimal?      @db.Decimal(8, 4)
  sentimentScore   Decimal?      @db.Decimal(8, 4)
  marketPriceLow   Decimal?      @db.Decimal(12, 2)
  marketPriceHigh  Decimal?      @db.Decimal(12, 2)
  source           String?
  metadata         Json?
  product          Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())

  @@index([productId, snapshotDate])
  @@index([domain, category, snapshotDate])
}

model ForecastSnapshot {
  id               String          @id @default(uuid()) @db.Uuid
  productId        String?         @db.Uuid
  scopeKey         String
  horizon          ForecastHorizon
  forecastDate     DateTime
  projectedDemand  Int?
  projectedRevenue Decimal?        @db.Decimal(12, 2)
  projectedProfit  Decimal?        @db.Decimal(12, 2)
  confidence       Decimal?        @db.Decimal(8, 4)
  modelVersion     String?
  metadata         Json?
  product          Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([productId, horizon, forecastDate])
  @@index([scopeKey, horizon, forecastDate])
}

model AiConversationSession {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String?          @db.Uuid
  channel     AiSessionChannel @default(WEB)
  title       String?
  contextType String?
  metadata    Json?
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages    AiConversationMessage[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId, createdAt])
  @@index([channel, createdAt])
}

model AiConversationMessage {
  id         String        @id @default(uuid()) @db.Uuid
  sessionId  String        @db.Uuid
  role       AiMessageRole
  content    String
  toolName   String?
  metadata   Json?
  session    AiConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())

  @@index([sessionId, createdAt])
}

model AiRecommendation {
  id         String                 @id @default(uuid()) @db.Uuid
  userId     String?                @db.Uuid
  productId  String?                @db.Uuid
  type       AiRecommendationType
  status     AiRecommendationStatus @default(OPEN)
  title      String
  summary    String
  priority   Int                    @default(0)
  confidence Decimal?               @db.Decimal(8, 4)
  metadata   Json?
  user       User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  product    Product?               @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@index([userId, status, createdAt])
  @@index([productId, status, createdAt])
  @@index([type, status, createdAt])
}
